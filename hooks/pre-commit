#!/usr/bin/env bash
# pre-commit — セキュリティ監査フック
#
# 実行順:
#   [1] gitleaks  — シークレット・プライベートパス検出
#   [2] trufflehog — 信頼性検証
#   [3] LLM 監査  — findings を LM Studio(port:1234) に渡しリスク分類
#
# 緊急スキップ: git commit --no-verify

set -uo pipefail

ROOT="$(git rev-parse --show-toplevel)"
LLM_URL="http://localhost:1234"
FAIL=0

STAGED_FILES="$(git diff --cached --name-only 2>/dev/null)"
if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT

GL_REPORT="$TMP_DIR/gitleaks.json"
TH_REPORT="$TMP_DIR/trufflehog.jsonl"

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  pre-commit セキュリティ監査"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ── [1] gitleaks ──────────────────────────────────────────────────────────────
if command -v gitleaks &>/dev/null; then
    printf "[1/3] gitleaks ... "
    gitleaks protect --staged --no-banner \
        --config "$ROOT/.gitleaks.toml" \
        --source "$ROOT" \
        --report-format json \
        --report-path "$GL_REPORT" \
        2>/dev/null || true

    # gitleaks は findings がなくても空ファイルを作ることがある
    GL_COUNT=$(python3 - "$GL_REPORT" << 'PYEOF'
import json, sys
try:
    data = json.load(open(sys.argv[1]))
    print(len(data) if isinstance(data, list) else 0)
except:
    print(0)
PYEOF
)
    if [ "${GL_COUNT:-0}" -gt 0 ]; then
        echo "⚠ ${GL_COUNT} 件検出"
        python3 - "$GL_REPORT" << 'PYEOF'
import json, sys
data = json.load(open(sys.argv[1]))
for item in data[:10]:
    rule   = item.get('RuleID', '?')
    f      = item.get('File', '?')
    line   = item.get('StartLine', '?')
    secret = item.get('Secret', '')[:60]
    print(f'  [{rule}] {f}:{line}  →  {secret}')
PYEOF
        FAIL=1
    else
        echo "✓ 検出なし"
    fi
else
    echo "[1/3] gitleaks ... スキップ (未インストール)"
fi

# ── [2] trufflehog ────────────────────────────────────────────────────────────
if command -v trufflehog &>/dev/null; then
    printf "[2/3] trufflehog ... "
    SCAN_DIR="$TMP_DIR/scan"
    mkdir -p "$SCAN_DIR"
    while IFS= read -r f; do
        mkdir -p "$SCAN_DIR/$(dirname "$f")"
        git show ":$f" > "$SCAN_DIR/$f" 2>/dev/null || true
    done <<< "$STAGED_FILES"

    trufflehog filesystem "$SCAN_DIR" \
        --no-verification --json 2>/dev/null > "$TH_REPORT" || true

    TH_COUNT=0
    [ -s "$TH_REPORT" ] && TH_COUNT=$(wc -l < "$TH_REPORT" | tr -d ' ')
    if [ "${TH_COUNT:-0}" -gt 0 ]; then
        echo "⚠ ${TH_COUNT} 件検出"
        python3 - "$TH_REPORT" << 'PYEOF'
import json, sys
for line in open(sys.argv[1]):
    line = line.strip()
    if not line:
        continue
    try:
        d   = json.loads(line)
        det = d.get('DetectorName', '?')
        raw = d.get('Raw', '')[:60]
        print(f'  [{det}]  {raw}')
    except Exception:
        pass
PYEOF
        FAIL=1
    else
        echo "✓ 検出なし"
    fi
else
    echo "[2/3] trufflehog ... スキップ (未インストール)"
fi

# ── [3] LLM リスク評価（findings が存在する場合のみ） ─────────────────────────
if [ "$FAIL" -ne 0 ]; then
    printf "[3/3] LLM リスク評価 (%s) ... " "$LLM_URL"

    if ! curl -sf --max-time 3 "$LLM_URL/v1/models" &>/dev/null; then
        echo "スキップ (LM Studio 未起動)"
    else
        # findings を txt に書き出して Python に渡す
        FINDINGS_TXT="$TMP_DIR/findings.txt"
        python3 - "$GL_REPORT" "$TH_REPORT" "$FINDINGS_TXT" << 'PYEOF'
import json, sys

gl_path   = sys.argv[1]
th_path   = sys.argv[2]
out_path  = sys.argv[3]
lines = []

# gitleaks findings
try:
    data = json.load(open(gl_path))
    for item in data:
        rule   = item.get('RuleID', '?')
        f      = item.get('File', '?')
        lineno = item.get('StartLine', '?')
        secret = item.get('Secret', '')[:80]
        lines.append(f'[gitleaks] rule={rule} file={f}:{lineno} value="{secret}"')
except Exception:
    pass

# trufflehog findings
try:
    for line in open(th_path):
        line = line.strip()
        if not line:
            continue
        d   = json.loads(line)
        det = d.get('DetectorName', '?')
        raw = d.get('Raw', '')[:80]
        lines.append(f'[trufflehog] detector={det} value="{raw}"')
except Exception:
    pass

open(out_path, 'w').write('\n'.join(lines))
PYEOF

        FINDINGS_CONTENT="$(cat "$FINDINGS_TXT" 2>/dev/null)"

        # OpenAI 互換ペイロードを Python で構築
        PAYLOAD_FILE="$TMP_DIR/payload.json"
        python3 - "$PAYLOAD_FILE" << PYEOF
import json, sys

findings = """$FINDINGS_CONTENT"""

system_msg = "あなたはセキュリティ監査の専門家です。git pre-commitフックで検出されたセキュリティ問題を分析し、リスク評価と修正指示を提供します。"

user_msg = """以下の検出結果を分析してください。

## 検出結果
{findings}

## 出力形式（JSONのみ、余分なテキスト不要）
{{"risk": "HIGH|MEDIUM|LOW", "summary": "問題の要約（1文）", "items": [{{"file": "path", "issue": "問題", "fix": "修正方法"}}]}}

判定基準:
- HIGH: 実際の秘密情報・個人情報がソースコードにハードコードされている
- MEDIUM: 内部パス・プライベートIPがデフォルト値やハードコードに含まれる
- LOW: ドキュメント内の例示など実害の低いもの""".format(findings=findings)

payload = {{
    "model": "local-model",
    "messages": [
        {{"role": "system", "content": system_msg}},
        {{"role": "user",   "content": user_msg}}
    ],
    "max_tokens": 512,
    "temperature": 0.05
}}

with open(sys.argv[1], 'w') as f:
    json.dump(payload, f)
PYEOF

        RESPONSE=$(curl -sf --max-time 90 \
            -H "Content-Type: application/json" \
            -d "@$PAYLOAD_FILE" \
            "$LLM_URL/v1/chat/completions" 2>/dev/null) || true

        if [ -z "$RESPONSE" ]; then
            echo "スキップ (応答タイムアウト)"
        else
            echo "$RESPONSE" > "$TMP_DIR/llm_response.json"
            python3 - "$TMP_DIR/llm_response.json" << 'PYEOF'
import json, re, sys

resp    = json.load(open(sys.argv[1]))
content = resp.get('choices', [{}])[0].get('message', {}).get('content', '').strip()

m = re.search(r'\{.*\}', content, re.DOTALL)
if not m:
    print('⚠ 応答パース失敗 (生テキスト): ' + content[:100])
    sys.exit(0)

try:
    data = json.loads(m.group())
except json.JSONDecodeError:
    print('⚠ JSON パースエラー')
    sys.exit(0)

risk    = data.get('risk', '?')
summary = data.get('summary', '')
items   = data.get('items', [])

icon = {'HIGH': '🔴', 'MEDIUM': '🟡', 'LOW': '🟢'}.get(risk, '⚪')
print(f'リスク: {icon} {risk}')
print(f'概要: {summary}')
for item in items:
    print(f'  📄 {item.get("file","?")}')
    print(f'     問題: {item.get("issue","")}')
    print(f'     修正: {item.get("fix","")}')
PYEOF
        fi
    fi
fi

# ── 結果 ──────────────────────────────────────────────────────────────────────
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [ "$FAIL" -ne 0 ]; then
    echo "  ✗ コミットをブロックしました。問題を修正してください。"
    echo "  緊急スキップ: git commit --no-verify"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 1
fi
echo "  ✓ 監査クリア — コミットを許可します"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
exit 0
