data/rulebook/*

# ── コンパイル済みバイナリ ────────────────────────────────────────────────────
.bin/
orchestrator/server

# ── Node.js ───────────────────────────────────────────────────────────────────
ui/node_modules/
ui/dist/
ui/dist-ssr/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
ai-agents/.venv/

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.suo
*.sw?

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
._*

# ── Claude CLI プロジェクトキャッシュ ─────────────────────────────────────────
.claude/

# ── 大容量 PDF 仕様書・テストレポート ────────────────────────────────────────
*.pdf
*.PDF
