# ── ローカル設定（絶対パス・秘匿情報を含む） ────────────────────────────────
config.env
*mock*

# ── ランタイム状態 ────────────────────────────────────────────────────────────
.pids
logs/*
!logs/.gitkeep
*.log

# ── データベース ──────────────────────────────────────────────────────────────
data/omni.db
data/omni.db-shm
data/omni.db-wal

# ── LLM モデルファイル（巨大バイナリ） ───────────────────────────────────────
*.gguf
*.safetensors
*.ckpt
*.pt
*.pth
data/models/

# ── 生成画像（バッチ生成結果） ────────────────────────────────────────────────
data/images/*
!data/images/.gitkeep

# ── ルールブック（著作物・push禁止） ────────────────────────────────────────
