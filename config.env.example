# ============================================================
#  Omni-Master 設定ファイル — テンプレート
#  このファイルをコピーして config.env を作成してください:
#    cp config.env.example config.env
#  config.env は .gitignore で管理対象外です。
# ============================================================

# ── データベース ──────────────────────────────────────────────
DB_PATH=/path/to/sw25-omni-master/data/omni.db

# ── Go サーバー ───────────────────────────────────────────────
ADDR=:8080

# ── ComfyUI（Windows 側または別マシン） ───────────────────────
# 画像生成を使わない場合は空文字のままにする
COMFY_URL=

# ── llama-server バイナリ ─────────────────────────────────────
# PATH に含まれている場合は "llama-server" のみでよい
LLAMA_SERVER=llama-server

# ── モデルファイル（フルパス） ────────────────────────────────
# GM 用: 高品質モデル（Gemma-4B 相当以上を推奨）
MODEL_GM=/path/to/models/gm_model.gguf

# NPC / Support 用: 軽量モデル（Gemma-2B 相当）
MODEL_NPC=/path/to/models/npc_model.gguf

# 埋め込み用: nomic-embed-text 推奨
MODEL_EMBED=/path/to/models/nomic-embed-text-v1.5.Q4_K_M.gguf

# ── LLM エンドポイント ────────────────────────────────────────
GM_URL=http://localhost:11430
SUPPORT_URL=http://localhost:11431
NPC_A_URL=http://localhost:11432
NPC_B_URL=http://localhost:11433
NPC_C_URL=http://localhost:11434
EMBED_URL=http://localhost:11435
